---
interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

// Dati strutturati BreadcrumbList (rich snippet su Google), con URL assoluti
const toAbs = (href: string) =>
  href ? new URL(href, Astro.site).href : new URL(Astro.url.pathname, Astro.site).href;
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.label,
    item: toAbs(item.href),
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-2 text-sm">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-2">
          {index > 0 && <span class="text-gray-400">/</span>}
          {item.href ? (
            <a
              href={item.href}
              class="text-blue-600 hover:underline focus:outline-none focus:ring-2 focus:ring-blue-500 rounded"
            >
              {item.label}
            </a>
          ) : (
            <span class="text-gray-700 font-medium" aria-current="page">
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

---
// Calendario mensile NAVIGANTE (coerente col modello a pagine dedicate):
// - frecce: sfogliano i mesi nel calendario (client-side, senza ricaricare)
// - titolo del mese: link alla pagina del mese (/sedute/AAAA/MM)
// - giorno con seduta: link alla seduta (se unica) o alla pagina del mese (se più d'una)
interface Props {
  sedute: any[];
}
const { sedute } = Astro.props;

const calData = sedute.map((s) => ({
  date: s.dataSeduta,
  url: `/ars_sicilia/sedute/${s.yearMonthDay.year}/${s.yearMonthDay.month}/${s.yearMonthDay.day}/${s.slug}`,
  numero: s.numero,
}));
---

<section class="mb-8" aria-label="Calendario delle sedute">
  <div class="card p-5 w-full max-w-lg">
    <div class="flex items-center justify-between gap-3 mb-3">
      <button id="cal-prev" type="button" aria-label="Mese precedente"
        class="w-8 h-8 flex items-center justify-center rounded-md border border-warm-300 text-navy-800 hover:bg-navy-50 disabled:opacity-30 disabled:cursor-not-allowed transition-colors shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <a id="cal-title" href="#"
        class="text-base font-display font-bold text-navy-800 px-3 text-center hover:text-amber-600 underline-offset-4 hover:underline transition-colors"></a>
      <button id="cal-next" type="button" aria-label="Mese successivo"
        class="w-8 h-8 flex items-center justify-center rounded-md border border-warm-300 text-navy-800 hover:bg-navy-50 disabled:opacity-30 disabled:cursor-not-allowed transition-colors shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>
    </div>

    <div class="grid grid-cols-7 gap-1 text-center text-[11px] font-semibold text-warm-500 mb-1">
      <div>LU</div><div>MA</div><div>ME</div><div>GI</div><div>VE</div><div>SA</div><div>DO</div>
    </div>
    <div id="cal-grid" class="grid grid-cols-7 gap-1 text-sm"></div>

    <p class="text-xs text-warm-500 mt-3 flex items-center gap-2">
      <span class="inline-block w-4 h-4 rounded bg-navy-100 border border-navy-200"></span>
      Giorni con seduta: clicca per aprirla. Il mese apre l'elenco del periodo.
    </p>
  </div>

  <script type="application/json" id="cal-data" set:html={JSON.stringify(calData)}></script>

  <script>
    function initCalendarioSedute() {
      const dataEl = document.getElementById('cal-data');
      const grid = document.getElementById('cal-grid');
      const title = document.getElementById('cal-title') as HTMLAnchorElement | null;
      const prev = document.getElementById('cal-prev') as HTMLButtonElement | null;
      const next = document.getElementById('cal-next') as HTMLButtonElement | null;
      if (!dataEl || !grid || !title || !prev || !next) return;

      const data = JSON.parse(dataEl.textContent || '[]');
      const MESI = ['Gennaio','Febbraio','Marzo','Aprile','Maggio','Giugno','Luglio','Agosto','Settembre','Ottobre','Novembre','Dicembre'];

      // data giorno -> elenco url sedute
      const byDate: Record<string, string[]> = {};
      data.forEach((s: any) => { (byDate[s.date] ||= []).push(s.url); });
      const months = [...new Set(data.map((s: any) => s.date.slice(0, 7)))].sort() as string[];
      if (!months.length) return;
      let idx = months.length - 1;

      const monthPath = (ym: string) => `/ars_sicilia/sedute/${ym.slice(0, 4)}/${ym.slice(5, 7)}`;

      function render() {
        const [y, m] = months[idx].split('-').map(Number);
        title!.textContent = `${MESI[m - 1]} ${y}`;
        title!.href = monthPath(months[idx]);
        const firstDow = (new Date(y, m - 1, 1).getDay() + 6) % 7;
        const days = new Date(y, m, 0).getDate();
        let html = '';
        for (let i = 0; i < firstDow; i++) html += '<div></div>';
        for (let d = 1; d <= days; d++) {
          const key = `${y}-${String(m).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
          const urls = byDate[key];
          if (urls && urls.length) {
            const href = urls.length === 1 ? urls[0] : monthPath(months[idx]);
            const label = urls.length === 1 ? `Vai alla seduta del ${d}` : `${urls.length} sedute il ${d}`;
            html += `<a href="${href}" title="${label}" class="h-9 flex items-center justify-center rounded-md font-bold bg-navy-100 text-navy-800 hover:bg-amber-500 hover:text-white focus:outline-none focus:ring-2 focus:ring-amber-600 transition-colors">${d}</a>`;
          } else {
            html += `<div class="h-9 flex items-center justify-center text-warm-400">${d}</div>`;
          }
        }
        grid!.innerHTML = html;
        prev!.disabled = idx === 0;
        next!.disabled = idx === months.length - 1;
      }

      // frecce: sfogliano i mesi nel calendario (no navigazione)
      prev.addEventListener('click', () => { if (idx > 0) { idx--; render(); } });
      next.addEventListener('click', () => { if (idx < months.length - 1) { idx++; render(); } });

      render();
    }

    document.addEventListener('astro:page-load', initCalendarioSedute);
  </script>
</section>

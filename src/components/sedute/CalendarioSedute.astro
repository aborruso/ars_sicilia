---
// Calendario mensile sfogliabile delle sedute: i giorni con seduta sono
// evidenziati e cliccabili (portano alla pagina della seduta). Tutto client-side.
interface Props {
  sedute: any[];
}
const { sedute } = Astro.props;

const calData = sedute.map((s) => ({
  date: s.dataSeduta,
  numero: s.numero,
  url: `/ars_sicilia/sedute/${s.yearMonthDay.year}/${s.yearMonthDay.month}/${s.yearMonthDay.day}/${s.slug}`,
}));
---

<section class="mb-8" aria-label="Calendario delle sedute">
  <div class="card p-5">
    <div class="flex items-center justify-between mb-4">
      <button
        id="cal-prev"
        type="button"
        aria-label="Mese precedente"
        class="w-9 h-9 flex items-center justify-center rounded-md border border-warm-300 text-navy-800 hover:bg-navy-50 disabled:opacity-30 disabled:cursor-not-allowed transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <h2 id="cal-title" class="text-lg md:text-xl font-display font-bold text-navy-800"></h2>
      <button
        id="cal-next"
        type="button"
        aria-label="Mese successivo"
        class="w-9 h-9 flex items-center justify-center rounded-md border border-warm-300 text-navy-800 hover:bg-navy-50 disabled:opacity-30 disabled:cursor-not-allowed transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>
    </div>

    <div class="grid grid-cols-7 gap-1 text-center text-xs font-semibold text-warm-500 mb-1">
      <div>LU</div><div>MA</div><div>ME</div><div>GI</div><div>VE</div><div>SA</div><div>DO</div>
    </div>
    <div id="cal-grid" class="grid grid-cols-7 gap-1"></div>

    <p class="text-xs text-warm-500 mt-3 flex items-center gap-2">
      <span class="inline-block w-4 h-4 rounded bg-navy-100 border border-navy-200"></span>
      I giorni evidenziati hanno una seduta: clicca per aprirla.
    </p>
  </div>

  <script type="application/json" id="cal-data" set:html={JSON.stringify(calData)}></script>

  <script>
    function initCalendarioSedute() {
      const dataEl = document.getElementById('cal-data');
      const grid = document.getElementById('cal-grid');
      const title = document.getElementById('cal-title');
      const prev = document.getElementById('cal-prev') as HTMLButtonElement | null;
      const next = document.getElementById('cal-next') as HTMLButtonElement | null;
      if (!dataEl || !grid || !title || !prev || !next) return;

      const data = JSON.parse(dataEl.textContent || '[]');
      const MESI = ['Gennaio','Febbraio','Marzo','Aprile','Maggio','Giugno','Luglio','Agosto','Settembre','Ottobre','Novembre','Dicembre'];

      const byDate: Record<string, any> = {};
      data.forEach((s: any) => { byDate[s.date] = s; });
      const months = [...new Set(data.map((s: any) => s.date.slice(0, 7)))].sort() as string[];
      if (!months.length) return;
      let idx = months.length - 1; // parte dal mese più recente

      function render() {
        const [y, m] = months[idx].split('-').map(Number);
        title!.textContent = `${MESI[m - 1]} ${y}`;
        const firstDow = (new Date(y, m - 1, 1).getDay() + 6) % 7; // settimana lunedì-based
        const days = new Date(y, m, 0).getDate();
        let html = '';
        for (let i = 0; i < firstDow; i++) html += '<div></div>';
        for (let d = 1; d <= days; d++) {
          const key = `${y}-${String(m).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
          const s = byDate[key];
          if (s) {
            html += `<a href="${s.url}" title="Seduta ${s.numero}" class="aspect-square flex items-center justify-center rounded-md bg-navy-100 text-navy-800 font-bold hover:bg-amber-500 hover:text-white focus:outline-none focus:ring-2 focus:ring-amber-600 transition-colors">${d}</a>`;
          } else {
            html += `<div class="aspect-square flex items-center justify-center text-warm-400 text-sm">${d}</div>`;
          }
        }
        grid!.innerHTML = html;
        prev!.disabled = idx === 0;
        next!.disabled = idx === months.length - 1;
      }

      prev.addEventListener('click', () => { if (idx > 0) { idx--; render(); } });
      next.addEventListener('click', () => { if (idx < months.length - 1) { idx++; render(); } });
      render();
    }

    document.addEventListener('astro:page-load', initCalendarioSedute);
  </script>
</section>

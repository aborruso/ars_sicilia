---
import PageLayout from '../../../../../../layouts/PageLayout.astro';
import Breadcrumb from '../../../../../../components/layout/Breadcrumb.astro';
import VideosByDate from '../../../../../../components/sedute/VideosByDate.astro';
import DisegniList from '../../../../../../components/sedute/DisegniList.astro';
import SedutaLlmExportButton from '../../../../../../components/sedute/SedutaLlmExportButton.astro';
import { loadSedute } from '../../../../../../lib/data-loader';
import { formatDate, formatDateShort } from '../../../../../../lib/utils';

export async function getStaticPaths() {
  const sedute = await loadSedute();
  // sedute è ordinato per data DESC: indice minore = più recente
  const navInfo = (s) =>
    s
      ? {
          numero: s.numero,
          dataSeduta: s.dataSeduta,
          url: `/ars_sicilia/sedute/${s.yearMonthDay.year}/${s.yearMonthDay.month}/${s.yearMonthDay.day}/${s.slug}`,
        }
      : null;

  return sedute.map((seduta, i) => ({
    params: {
      anno: seduta.yearMonthDay.year,
      mese: seduta.yearMonthDay.month,
      giorno: seduta.yearMonthDay.day,
      seduta: seduta.slug,
    },
    props: {
      seduta,
      prev: navInfo(sedute[i + 1]), // seduta precedente (più vecchia)
      next: navInfo(sedute[i - 1]), // seduta successiva (più recente)
    },
  }));
}

const { seduta, prev, next } = Astro.props;

const breadcrumbs = [
  { label: 'Home', href: '/ars_sicilia/' },
  { label: 'Sedute', href: '/ars_sicilia/sedute/1' },
  { label: `Seduta ${seduta.numero}`, href: '' },
];
---

<PageLayout
  title={`Seduta n. ${seduta.numero} del ${formatDate(seduta.dataSeduta)}`}
  description={`Video, documenti e trascrizioni della seduta ${seduta.numero} dell'Assemblea Regionale Siciliana del ${formatDate(seduta.dataSeduta)}. ${seduta.videos.length} video disponibili${seduta.disegniLegge.length > 0 ? `, disegni di legge: ${seduta.disegniLegge.map(d => d.numero).join(', ')}` : ''}.`}
  ogType="article"
>
  <Breadcrumb items={breadcrumbs} />

  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-2">
        Seduta n. {seduta.numero}
      </h1>
      <p class="text-lg text-gray-600">
        {formatDate(seduta.dataSeduta)}
      </p>
    </header>

    <!-- Link documenti -->
    <div class="flex flex-wrap gap-3 mb-8">
      <a href={seduta.urlPagina} class="btn-primary" target="_blank" rel="noopener noreferrer">
        📄 Pagina ARS
        <span class="sr-only">(apre in una nuova finestra)</span>
      </a>

      {seduta.odgUrl && (
        <a href={seduta.odgUrl} class="btn-secondary" target="_blank" rel="noopener noreferrer">
          📋 Ordine del Giorno (PDF)
          <span class="sr-only">(apre in una nuova finestra)</span>
        </a>
      )}

      <SedutaLlmExportButton seduta={seduta} />

      {(seduta.resocontoStenograficoUrl || seduta.resocontoProvvisorioUrl) && (
        <a
          href={seduta.resocontoStenograficoUrl || seduta.resocontoProvvisorioUrl}
          class="btn-secondary"
          target="_blank"
          rel="noopener noreferrer"
        >
          📝 Resoconto {seduta.resocontoStenograficoUrl ? 'Stenografico' : 'Provvisorio'} (PDF)
          <span class="sr-only">(apre in una nuova finestra)</span>
        </a>
      )}

      {seduta.allegatoUrl && (
        <a href={seduta.allegatoUrl} class="btn-secondary" target="_blank" rel="noopener noreferrer">
          📎 Allegato (PDF)
          <span class="sr-only">(apre in una nuova finestra)</span>
        </a>
      )}
    </div>

    <!-- Disegni di legge -->
    <DisegniList disegni={seduta.disegniLegge} />

    <!-- Video raggruppati per data -->
    <VideosByDate seduta={seduta} />
  </article>

  <!-- Navigazione tra sedute (precedente / successiva) -->
  <nav class="flex items-stretch gap-4 mt-12 pt-6 border-t border-warm-200" aria-label="Naviga tra le sedute">
    {prev ? (
      <a href={prev.url} class="group flex-1 flex flex-col gap-1 p-4 rounded-lg border border-warm-200 hover:border-navy-800 hover:bg-navy-50 transition-colors">
        <span class="text-xs font-semibold text-warm-500 inline-flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          Seduta precedente
        </span>
        <span class="font-display font-bold text-navy-800">Seduta {prev.numero}</span>
        <span class="text-sm text-warm-600">{formatDateShort(prev.dataSeduta)}</span>
      </a>
    ) : (
      <div class="flex-1"></div>
    )}
    {next ? (
      <a href={next.url} class="group flex-1 flex flex-col gap-1 p-4 rounded-lg border border-warm-200 hover:border-navy-800 hover:bg-navy-50 transition-colors text-right items-end">
        <span class="text-xs font-semibold text-warm-500 inline-flex items-center gap-1">
          Seduta successiva
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </span>
        <span class="font-display font-bold text-navy-800">Seduta {next.numero}</span>
        <span class="text-sm text-warm-600">{formatDateShort(next.dataSeduta)}</span>
      </a>
    ) : (
      <div class="flex-1"></div>
    )}
  </nav>
</PageLayout>

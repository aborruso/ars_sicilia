---
import PageLayout from '../../layouts/PageLayout.astro';
import DDLCard from '../../components/ddl/DDLCard.astro';
import Pagination from '../../components/ui/Pagination.astro';
import { loadDDLs } from '../../lib/data-loader';

export async function getStaticPaths() {
  const ITEMS_PER_PAGE = 10;
  const ddls = await loadDDLs();
  const totalPages = Math.ceil(ddls.length / ITEMS_PER_PAGE);

  return Array.from({ length: totalPages }, (_, i) => {
    const page = i + 1;
    const start = i * ITEMS_PER_PAGE;
    const end = start + ITEMS_PER_PAGE;

    return {
      params: { page: String(page) },
      props: {
        ddls: ddls.slice(start, end),
        currentPage: page,
        totalPages,
        allDDLs: ddls,
      },
    };
  });
}

const { ddls, currentPage, totalPages, allDDLs } = Astro.props;

// Dati minimi per la ricerca client-side (tutti i DDL, da qualsiasi pagina)
const searchData = allDDLs.map((d) => ({
  numero: d.numero,
  legislatura: d.legislatura,
  titolo: d.titolo,
  urlDisegno: d.urlDisegno,
  sedute: d.sedute.map((s) => ({
    numero: s.numero,
    dataSeduta: s.dataSeduta,
    slug: s.slug,
    ymd: s.yearMonthDay,
  })),
}));
---

<PageLayout
  title={`DDL ARS - Pagina ${currentPage}`}
  description={`Elenco disegni di legge dell'Assemblea Regionale Siciliana - Pagina ${currentPage} di ${totalPages}`}
>
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">
      Disegni di Legge
    </h1>
    <p class="text-lg text-warm-600 mb-2">
      Qui la lista dei disegni di legge presenti in ordine del giorno nelle <a href="/ars_sicilia/sedute/1" class="text-navy-800 hover:text-amber-600 underline underline-offset-2">sedute</a> archiviate in questo sito
    </p>
    <p class="text-sm text-warm-500" id="ddl-page-info">
      Pagina {currentPage} di {totalPages}
    </p>
  </div>

  <!-- Ricerca DDL (numero o descrizione) -->
  <div class="mb-8">
    <label for="ddl-search" class="sr-only">Cerca un disegno di legge per numero o titolo</label>
    <div class="relative">
      <svg class="w-5 h-5 text-warm-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        type="search"
        id="ddl-search"
        placeholder="Cerca per numero (es. 1030) o descrizione…"
        autocomplete="off"
        class="w-full pl-10 pr-4 py-3 border border-warm-300 rounded-lg text-base focus:outline-none focus:ring-2 focus:ring-amber-600 focus:border-amber-600"
      />
    </div>
    <p id="ddl-search-count" class="text-sm text-warm-500 mt-2 hidden"></p>
  </div>

  <!-- Lista paginata (vista di default) -->
  <div id="ddl-list">
    <div class="space-y-6">
      {ddls.map((ddl) => (
        <DDLCard ddl={ddl} />
      ))}
    </div>
    <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/ars_sicilia/ddl" />
  </div>

  <!-- Risultati ricerca (client-side) -->
  <div id="ddl-search-results" class="space-y-6 hidden"></div>

  <script type="application/json" id="ddl-search-data" set:html={JSON.stringify(searchData)}></script>

  <script>
    const BASE = '/ars_sicilia';

    function esc(s: string): string {
      return String(s).replace(/[&<>"']/g, (c) => (
        { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string
      ));
    }

    function fmtDate(iso: string): string {
      const [y, m, d] = (iso || '').split('-');
      return d && m && y ? `${d}/${m}/${y}` : (iso || '');
    }

    function cardHTML(ddl: any): string {
      const sedute = ddl.sedute.map((s: any) => `
        <a href="${BASE}/sedute/${s.ymd.year}/${s.ymd.month}/${s.ymd.day}/${s.slug}"
           class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-navy-800 bg-navy-50 hover:bg-navy-100 border border-navy-200 rounded-md transition-colors duration-200">
          <span>Seduta ${s.numero}</span><span class="text-warm-500">${fmtDate(s.dataSeduta)}</span>
        </a>`).join('');
      return `
        <article class="card group hover:border-l-navy-800 transition-all duration-300">
          <div class="p-6 pb-4">
            <div class="mb-4">
              <h2 class="text-2xl md:text-3xl font-display font-bold text-navy-800 mb-2 leading-tight">
                <a href="${esc(ddl.urlDisegno)}" target="_blank" rel="noopener noreferrer"
                   class="hover:text-amber-600 transition-colors duration-200">DDL n. ${esc(ddl.numero)}</a>
              </h2>
              <div class="inline-flex items-center gap-2 text-sm text-warm-600 font-medium mb-3">
                <span class="px-2 py-0.5 bg-navy-100 text-navy-800 rounded">Legislatura ${esc(ddl.legislatura)}</span>
                <span class="text-warm-400">•</span>
                <span>${ddl.sedute.length} sedute</span>
              </div>
              <p class="text-base text-warm-700 leading-relaxed">${esc(ddl.titolo)}</p>
            </div>
            <div class="pt-3 border-t border-warm-200">
              <p class="text-sm text-warm-600 font-medium mb-2">Sedute in cui è stato discusso:</p>
              <div class="flex flex-wrap gap-2">${sedute}</div>
            </div>
          </div>
        </article>`;
    }

    function normalize(s: string): string {
      return (s || '').toLowerCase().trim();
    }

    function initDDLSearch() {
      const data = JSON.parse(document.getElementById('ddl-search-data')?.textContent || '[]');
      const input = document.getElementById('ddl-search') as HTMLInputElement | null;
      const listEl = document.getElementById('ddl-list');
      const resultsEl = document.getElementById('ddl-search-results');
      const countEl = document.getElementById('ddl-search-count');
      const pageInfo = document.getElementById('ddl-page-info');
      if (!input || !resultsEl) return;

      function search(q: string) {
      const query = normalize(q);
      if (!query) {
        listEl?.classList.remove('hidden');
        resultsEl?.classList.add('hidden');
        countEl?.classList.add('hidden');
        pageInfo?.classList.remove('hidden');
        if (resultsEl) resultsEl.innerHTML = '';
        return;
      }
      const matches = data.filter((d: any) =>
        normalize(d.numero).includes(query) || normalize(d.titolo).includes(query)
      );
      if (resultsEl) {
        resultsEl.innerHTML = matches.length
          ? matches.map(cardHTML).join('')
          : '<p class="text-warm-600 py-8 text-center">Nessun disegno di legge trovato.</p>';
      }
      if (countEl) {
        countEl.textContent = `${matches.length} risultat${matches.length === 1 ? 'o' : 'i'} per "${q.trim()}"`;
        countEl.classList.remove('hidden');
      }
        listEl?.classList.add('hidden');
        resultsEl?.classList.remove('hidden');
        pageInfo?.classList.add('hidden');
      }

      function syncURL(q: string) {
        const url = new URL(window.location.href);
        if (q.trim()) url.searchParams.set('q', q.trim());
        else url.searchParams.delete('q');
        history.replaceState(null, '', url.toString());
      }

      input.addEventListener('input', (e) => {
        const v = (e.target as HTMLInputElement).value;
        search(v);
        syncURL(v);
      });

      // Ricerca pre-attivata da ?q= (link condivisibili)
      const initialQ = new URLSearchParams(window.location.search).get('q');
      if (initialQ) {
        input.value = initialQ;
        search(initialQ);
      }
    }

    // Esegue al primo load e dopo ogni navigazione con ViewTransitions
    document.addEventListener('astro:page-load', initDDLSearch);
  </script>
</PageLayout>
